generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

enum AccountCategory {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum AccountType {
  CASH
  BANK
  INVENTORY
  CUSTOMER
  SUPPLIER
  SALES
  PURCHASE
  EXPENSE
  STOCK_WRITE_OFF
  SALES_RETURN
  PURCHASE_RETURN
  EQUITY
  GENERAL
}

enum VoucherType {
  SALES
  PURCHASE
  RECEIPT
  PAYMENT
  CREDIT_NOTE
  DEBIT_NOTE
  OPENING
}

enum PaymentMode {
  CASH
  BANK
}

enum DocumentPaymentStatus {
  UNPAID
  PARTIAL
  PAID
  OVERDUE
  VOID
}

enum AllocationDocumentType {
  INVOICE
  PURCHASE
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
  shop      Shop?
}

model Shop {
  id         String     @id @default(uuid())
  userId     String     @unique
  shopName   String
  ownerName  String
  gstNumber  String?
  phone      String
  email      String?
  address    String
  state      String
  pincode    String
  createdAt  DateTime   @default(now())
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  products       Product[]
  customers      Customer[]
  suppliers      Supplier[]
  invoices       Invoice[]
  purchases      Purchase[]
  invoiceAllocations  InvoiceAllocation[]
  purchaseAllocations PurchaseAllocation[]
  salesReturns       SalesReturn[]
  purchaseReturns    PurchaseReturn[]
  stockWriteOffs     StockWriteOff[]
  accounts       Account[]
  journals       JournalEntry[]
  godowns        Godown[]
  batches        Batch[]
  purchaseOrders PurchaseOrder[]
  salesSchemes   SalesScheme[]
  stockAudits    StockAudit[]
}

model Product {
  id           String        @id @default(uuid())
  shopId       String
  name         String
  category     String?
  price        Float
  stock        Int           @default(0)
  hsnCode            String?       // HSN / SAC code for GST compliance
  gstRate            Float         @default(18) // product-specific GST rate in %
  mrp                Float?        // Maximum Retail Price
  retailRate         Float?        // Retail selling rate
  wholesaleRate      Float?        // Wholesale rate
  distributorRate    Float?        // Distributor / stockist rate
  saltComposition    String?
  minStockLevel      Int?
  reorderLevel       Int?          // trigger low-stock alert when stock <= reorderLevel
  maxStockLevel      Int?
  reorderQuantity    Int?
  primarySupplierId  String?
  barcode            String?       // EAN / Code128 barcode value
  createdAt          DateTime      @default(now())
  shop               Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  primarySupplier    Supplier?     @relation("PrimarySupplierProducts", fields: [primarySupplierId], references: [id], onDelete: SetNull)
  invoiceItems       InvoiceItem[]
  salesReturnItems   SalesReturnItem[]
  purchaseReturnItems PurchaseReturnItem[]
  stockWriteOffItems StockWriteOffItem[]
  stockAuditItems    StockAuditItem[]
  batches            Batch[]
  godownStock        GodownStock[]
  purchaseOrderItems PurchaseOrderItem[]
  salesSchemes       SalesScheme[]
  purchaseItems      PurchaseItem[]

  @@index([shopId])
  @@index([primarySupplierId])
  @@index([saltComposition])
}

model Customer {
  id        String    @id @default(uuid())
  shopId    String
  accountId String?   @unique
  name      String
  phone     String?
  email     String?
  address    String?
  state      String?   // State for CGST/SGST vs IGST determination
  priceLevel String    @default("RETAIL") // RETAIL | WHOLESALE | DISTRIBUTOR | MRP
  createdAt  DateTime  @default(now())
  shop      Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  account   Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  invoices  Invoice[]
  salesReturns SalesReturn[]

  @@index([shopId])
}

model Supplier {
  id        String    @id @default(uuid())
  shopId    String
  accountId String?   @unique
  name      String
  phone     String?
  email     String?
  address   String?
  createdAt DateTime  @default(now())
  shop      Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  account   Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  purchases       Purchase[]
  purchaseReturns PurchaseReturn[]
  primaryProducts Product[] @relation("PrimarySupplierProducts")

  @@index([shopId])
}

model Invoice {
  id             String        @id @default(uuid())
  shopId         String
  customerId     String
  invoiceNo      String?
  totalAmount    Float
  paidAmount     Float         @default(0)
  outstandingAmount Float      @default(0)
  paymentStatus  String        @default("UNPAID")
  dueDate        DateTime?
  lastPaymentAt  DateTime?
  subtotal       Float         @default(0)
  discountAmount    Float         @default(0)
  discountType      String        @default("none") // "none" | "trade" | "cash" | "volume"
  cashDiscountPct   Float         @default(0)   // bill-level cash discount %
  cashDiscountAmount Float        @default(0)   // computed cash discount ₹
  gstAmount      Float         @default(0)
  cgstAmount     Float         @default(0)
  sgstAmount     Float         @default(0)
  igstAmount     Float         @default(0)
  status         String        @default("paid")
  createdAt      DateTime      @default(now())
  shop           Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer       Customer      @relation(fields: [customerId], references: [id])
  items          InvoiceItem[]
  allocations    InvoiceAllocation[]
  salesReturns   SalesReturn[]

  @@index([shopId])
  @@index([customerId])
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  productId   String
  quantity    Int                  // total stock deducted (billedQty + freeQty)
  billedQty   Int     @default(0)  // qty charged to customer
  freeQty     Int     @default(0)  // qty given free under scheme
  schemeId    String?              // which SalesScheme triggered the free qty
  price       Float
  discountPct Float   @default(0)  // trade discount %
  hsnCode     String?              // snapshot of HSN at time of sale
  taxRate     Float   @default(18) // GST rate at time of sale
  scheme      SalesScheme?  @relation(fields: [schemeId], references: [id], onDelete: SetNull)
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id])
  salesReturnItems SalesReturnItem[]

  @@index([invoiceId])
}

model Purchase {
  id          String         @id @default(uuid())
  shopId      String
  supplierId  String?
  billNo      String?
  vendorName  String
  totalAmount Float
  paidAmount  Float          @default(0)
  outstandingAmount Float    @default(0)
  paymentStatus String       @default("UNPAID")
  dueDate     DateTime?
  lastPaymentAt DateTime?
  imageUrl    String?
  createdAt   DateTime       @default(now())
  shop        Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  supplier    Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  items       PurchaseItem[]
  batches     Batch[]
  allocations PurchaseAllocation[]
  purchaseReturns PurchaseReturn[]

  @@index([shopId])
}

model PurchaseItem {
  id           String   @id @default(uuid())
  purchaseId   String
  productId    String?
  productName  String
  batchNo      String?
  pack         String?
  quantity     Int
  freeQty      Int      @default(0)
  price        Float
  discountPct  Float    @default(0)
  amount       Float    @default(0)
  purchase     Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  purchaseReturnItems PurchaseReturnItem[]

  @@index([purchaseId])
  @@index([productId])
}

model Account {
  id             String          @id @default(uuid())
  shopId         String
  code           String
  name           String
  category       AccountCategory
  type           AccountType     @default(GENERAL)
  openingBalance Float           @default(0)
  isSystem       Boolean         @default(false)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  shop           Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer       Customer?
  supplier       Supplier?
  journalLines   JournalLine[]

  @@unique([shopId, code])
  @@index([shopId, category])
}

model JournalEntry {
  id          String        @id @default(uuid())
  shopId      String
  entryNo     String        @unique
  voucherType VoucherType
  entryDate   DateTime      @default(now())
  reference   String?
  narration   String?
  sourceModel String?
  sourceId    String?
  createdAt   DateTime      @default(now())
  shop        Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  lines       JournalLine[]
  invoiceAllocations  InvoiceAllocation[]
  purchaseAllocations PurchaseAllocation[]
  salesReturns       SalesReturn[]
  purchaseReturns    PurchaseReturn[]
  stockWriteOffs     StockWriteOff[]

  @@index([shopId, voucherType, entryDate])
  @@index([shopId, sourceModel, sourceId])
}

model JournalLine {
  id             String       @id @default(uuid())
  journalEntryId String
  accountId      String
  debit          Float        @default(0)
  credit         Float        @default(0)
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account        Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([journalEntryId])
  @@index([accountId])
}

// ─── Advanced Inventory ───────────────────────────────────────────────────────

model Godown {
  id        String        @id @default(uuid())
  shopId    String
  name      String
  address   String?
  isDefault Boolean       @default(false)
  createdAt DateTime      @default(now())
  shop      Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  stock       GodownStock[]
  batches     Batch[]
  stockAudits StockAudit[]

  @@index([shopId])
}

model GodownStock {
  id        String  @id @default(uuid())
  godownId  String
  productId String
  quantity  Int     @default(0)
  godown    Godown  @relation(fields: [godownId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([godownId, productId])
  @@index([godownId])
  @@index([productId])
}

model Batch {
  id          String    @id @default(uuid())
  shopId      String
  productId   String
  godownId    String?
  purchaseId  String?
  batchNumber String
  mfgDate     DateTime?
  expiryDate  DateTime?
  quantity    Int       @default(0)
  createdAt   DateTime  @default(now())
  shop        Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id])
  godown      Godown?   @relation(fields: [godownId], references: [id])
  purchase    Purchase? @relation(fields: [purchaseId], references: [id])
  purchaseReturnItems PurchaseReturnItem[]
  stockWriteOffItems  StockWriteOffItem[]

  @@index([shopId])
  @@index([productId])
  @@index([expiryDate])
}

model PurchaseOrder {
  id          String              @id @default(uuid())
  shopId      String
  poNumber    String?
  vendorName  String              @default("")
  status      String              @default("draft")
  totalAmount Float               @default(0)
  notes       String?
  createdAt   DateTime            @default(now())
  shop        Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)
  items       PurchaseOrderItem[]

  @@index([shopId])
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  productId       String?
  productName     String
  quantity        Int
  price           Float         @default(0)
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product         Product?      @relation(fields: [productId], references: [id])

  @@index([purchaseOrderId])
}

model InvoiceAllocation {
  id             String       @id @default(uuid())
  shopId         String
  invoiceId      String
  journalEntryId String
  amount         Float
  allocatedAt    DateTime     @default(now())
  createdAt      DateTime     @default(now())
  shop           Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  invoice        Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@index([shopId, invoiceId])
  @@index([shopId, journalEntryId])
  @@index([allocatedAt])
}

model PurchaseAllocation {
  id             String       @id @default(uuid())
  shopId         String
  purchaseId     String
  journalEntryId String
  amount         Float
  allocatedAt    DateTime     @default(now())
  createdAt      DateTime     @default(now())
  shop           Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  purchase       Purchase     @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@index([shopId, purchaseId])
  @@index([shopId, journalEntryId])
  @@index([allocatedAt])
}

model StockAudit {
  id            String          @id @default(uuid())
  shopId        String
  godownId      String
  auditDate     DateTime        @default(now())
  status        String          @default("draft")
  notes         String?
  postedAt      DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  shop          Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  godown        Godown          @relation(fields: [godownId], references: [id], onDelete: Cascade)
  items         StockAuditItem[]

  @@index([shopId, godownId, auditDate])
  @@index([status])
}

model StockAuditItem {
  id            String     @id @default(uuid())
  stockAuditId  String
  productId     String
  expectedQty   Int
  physicalQty   Int        @default(0)
  differenceQty Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  stockAudit    StockAudit @relation(fields: [stockAuditId], references: [id], onDelete: Cascade)
  product       Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([stockAuditId, productId])
  @@index([productId])
}

model SalesReturn {
  id             String          @id @default(uuid())
  shopId         String
  invoiceId      String
  customerId     String
  journalEntryId String?         @unique
  noteNo         String
  reason         String?
  totalAmount    Float
  createdAt      DateTime        @default(now())
  shop           Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  invoice        Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  customer       Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  journalEntry   JournalEntry?   @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)
  items          SalesReturnItem[]

  @@unique([shopId, noteNo])
  @@index([shopId, invoiceId])
  @@index([shopId, createdAt])
}

model SalesReturnItem {
  id            String       @id @default(uuid())
  salesReturnId String
  invoiceItemId String?
  productId     String
  quantity      Int
  rate          Float
  amount        Float
  salesReturn   SalesReturn  @relation(fields: [salesReturnId], references: [id], onDelete: Cascade)
  invoiceItem   InvoiceItem? @relation(fields: [invoiceItemId], references: [id], onDelete: SetNull)
  product       Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([salesReturnId])
  @@index([productId])
}

model PurchaseReturn {
  id             String               @id @default(uuid())
  shopId         String
  purchaseId     String
  supplierId     String
  journalEntryId String?              @unique
  noteNo         String
  reason         String?
  totalAmount    Float
  createdAt      DateTime             @default(now())
  shop           Shop                 @relation(fields: [shopId], references: [id], onDelete: Cascade)
  purchase       Purchase             @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  supplier       Supplier             @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  journalEntry   JournalEntry?        @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)
  items          PurchaseReturnItem[]

  @@unique([shopId, noteNo])
  @@index([shopId, purchaseId])
  @@index([shopId, createdAt])
}

model PurchaseReturnItem {
  id               String          @id @default(uuid())
  purchaseReturnId String
  purchaseItemId   String?
  productId        String
  batchId          String?
  quantity         Int
  rate             Float
  amount           Float
  purchaseReturn   PurchaseReturn  @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)
  purchaseItem     PurchaseItem?   @relation(fields: [purchaseItemId], references: [id], onDelete: SetNull)
  product          Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  batch            Batch?          @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([purchaseReturnId])
  @@index([productId])
  @@index([batchId])
}

model StockWriteOff {
  id             String             @id @default(uuid())
  shopId         String
  journalEntryId String?            @unique
  referenceNo    String
  reason         String
  notes          String?
  totalAmount    Float
  createdAt      DateTime           @default(now())
  shop           Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  journalEntry   JournalEntry?      @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)
  items          StockWriteOffItem[]

  @@unique([shopId, referenceNo])
  @@index([shopId, createdAt])
}

model StockWriteOffItem {
  id              String         @id @default(uuid())
  stockWriteOffId String
  productId       String
  batchId         String?
  quantity        Int
  unitCost        Float
  amount          Float
  stockWriteOff   StockWriteOff  @relation(fields: [stockWriteOffId], references: [id], onDelete: Cascade)
  product         Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  batch           Batch?         @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([stockWriteOffId])
  @@index([productId])
  @@index([batchId])
}

model SalesScheme {
  id           String        @id @default(uuid())
  shopId       String
  productId    String
  name         String
  type         String        @default("FREE_QTY") // FREE_QTY | PERCENTAGE
  minQty       Int
  freeQty      Int           @default(0)
  discountPct  Float         @default(0)
  startDate    DateTime?
  endDate      DateTime?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  shop         Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product      Product       @relation(fields: [productId], references: [id])
  invoiceItems InvoiceItem[]

  @@index([shopId])
  @@index([productId])
  @@index([isActive])
}


